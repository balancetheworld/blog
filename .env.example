# =====================================
# Blog 环境变量配置示例
# =====================================
# 部署时请复制此文件为 .env 并填写真实值

# -------------------------------------
# 后端配置
# -------------------------------------
SESSION_SECRET=请修改为一个随机的密钥
RESEND_API_KEY=re_你的Resend_API_Key
RESEND_FROM_EMAIL=noreply@smob.cc
FRONTEND_URL=https://blog.smob.cc
COOKIE_SECURE=true

# -------------------------------------
# 密钥生成方法：
# -------------------------------------
# SESSION_SECRET 可以用以下命令生成：
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
